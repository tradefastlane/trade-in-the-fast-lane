# Public browser-safe Supabase settings.
# Copy this file to .env.local for local online-multiplayer testing.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional only when the market API is hosted on a different domain.
# Leave blank when the Node service serves both the game and /api.
VITE_MARKET_API_URL=
